<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── Folder selection ───────────────────────────────────── -->

        <TextView
            android:id="@+id/folderUriText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/no_folder"
            android:textSize="14sp" />

        <Button
            android:id="@+id/chooseFolderButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="@string/choose_folder" />

        <Button
            android:id="@+id/watchDownloadsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/watch_downloads" />

        <!-- ── All Files Access permission ───────────────────────── -->

        <TextView
            android:id="@+id/allFilesStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:textSize="12sp" />

        <Button
            android:id="@+id/requestAllFilesButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:text="@string/request_all_files" />

        <!-- ── Watch control ──────────────────────────────────────── -->

        <Button
            android:id="@+id/toggleWatchButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/start_watching" />

        <TextView
            android:id="@+id/serviceStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/service_stopped"
            android:textSize="14sp" />

        <!-- ── Event log ──────────────────────────────────────────── -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="@string/event_log_label"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/eventLogText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:fontFamily="monospace"
            android:text="—"
            android:textSize="11sp" />

        <!-- ── Last proposal ──────────────────────────────────────── -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="@string/last_proposal"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/proposalText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="—"
            android:textSize="12sp" />

    </LinearLayout>

</ScrollView>
